# Configuração de Ambiente para STAGING (Vercel/Netlify)

# URL da API do Supabase - Projeto de Staging
VITE_SUPABASE_URL="https://seu-projeto-staging.supabase.co"

# Chave Anônima do Supabase - Projeto de Staging
VITE_SUPABASE_ANON_KEY="sua-anon-key-de-staging"

# IMPORTANTE:
# Variáveis como RIOT_API_KEY ou SERVICE_ROLE_KEY NÃO devem ir para o frontend.
# Elas devem ser configuradas exclusivamente nas Edge Functions (Supabase CLI ou Painel do Supabase).
