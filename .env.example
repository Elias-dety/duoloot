# Credenciais do Supabase — encontre no painel: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (Supabase Edge Functions — NÃO usar prefixo VITE_)
